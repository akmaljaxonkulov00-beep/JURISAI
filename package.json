{
  "name": "jurisai",
  "version": "4.3.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test && npm run test:e2e",
    "test:ai": "node test-all-ai-functions.js",
    "test:groq": "node test-groq-api.js",
    "test:groq:unsafe": "$env:NODE_TLS_REJECT_UNAUTHORIZED='0'; node test-groq-api.js",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "verify": "node scripts/verify.js",
    "setup": "node scripts/setup.js",
    "clean": "rd /s /q .next node_modules",
    "clean:cache": "rd /s /q .next",
    "reinstall": "npm run clean && npm install",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "build:netlify": "set NODE_OPTIONS=--max-old-space-size=4096 && next build",
    "netlify:dev": "netlify dev",
    "netlify:build": "npm run build",
    "build:standalone": "set NODE_OPTIONS=--max-old-space-size=4096 && next build",
    "prepare": "husky install",
    "postinstall": "npm run prepare"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@langchain/core": "^0.2.36",
    "@langchain/openai": "^0.0.23",
    "@prisma/client": "^5.20.0",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/auth-helpers-react": "^0.15.0",
    "@supabase/supabase-js": "^2.105.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "docxtemplater": "^3.68.6",
    "langchain": "^0.1.37",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "openai": "^6.35.0",
    "prisma": "^5.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "recharts": "^3.8.1",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^4.29.0",
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^8.0.3",
    "jsdom": "^23.0.1",
    "lint-staged": "^15.2.0",
    "netlify-cli": "^17.0.0",
    "postcss": "^8.5.13",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "vitest": "^1.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
