// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  phone           String?
  avatarUrl       String?   @map("avatar_url")
  timezone        String    @default("UTC")
  language        String    @default("uz")
  role            UserRole  @default(STUDENT)
  status          UserStatus @default(ACTIVE)
  emailVerified   Boolean   @default(false) @map("email_verified")
  phoneVerified   Boolean   @default(false) @map("phone_verified")
  lastLogin       DateTime? @map("last_login")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // Relations
  subscriptions   Subscription[]
  paymentMethods  PaymentMethod[]
  invoices        Invoice[]
  usageTracking   UsageTracking[]
  userAnalytics   UserAnalytics[]
  achievements    Achievement[]
  iracCases       IracCase[]
  apiKeys         ApiKey[]
  organizationMembers OrganizationMember[]
  feedback        Feedback[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([role])
  @@index([createdAt])
  @@index([email, status])
  @@map("users")
}

model Organization {
  id                String    @id @default(uuid())
  name              String
  slug              String    @unique
  description       String?
  logoUrl           String?   @map("logo_url")
  website           String?
  industry          String?
  size              String?
  country           String?
  city              String?
  address           String?
  phone             String?
  email             String?
  taxId             String?   @map("tax_id")
  registrationNumber String?  @map("registration_number")
  status            OrgStatus @default(ACTIVE)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  // Relations
  subscriptions     Subscription[]
  paymentMethods    PaymentMethod[]
  invoices          Invoice[]
  organizationMembers OrganizationMember[]
  usageTracking     UsageTracking[]
  organizationAnalytics OrganizationAnalytics[]
  apiKeys           ApiKey[]
  iracCases         IracCase[]
  achievements      Achievement[]

  @@map("organizations")
}

model OrganizationMember {
  id            String    @id @default(uuid())
  organizationId String    @map("organization_id")
  userId        String    @map("user_id")
  role          OrgRole   @default(MEMBER)
  permissions   Json      @default("{}")
  joinedAt      DateTime  @default(now()) @map("joined_at")
  invitedBy     String?   @map("invited_by")
  status        MemberStatus @default(ACTIVE)

  // Relations
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model SubscriptionPlan {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  price       Decimal   @db.Decimal(10, 0)
  currency    String    @default("UZS")
  billingCycle BillingCycle @map("billing_cycle")
  trialDays   Int       @default(0) @map("trial_days")
  features    Json      @default("[]")
  limits      Json      @default("{}")
  isActive    Boolean   @default(true) @map("is_active")
  isPublic    Boolean   @default(true) @map("is_public")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                    String    @id @default(uuid())
  userId                String?   @map("user_id")
  organizationId        String?   @map("organization_id")
  planId                String    @map("plan_id")
  status                SubStatus  @default(ACTIVE)
  currentPeriodStart    DateTime  @map("current_period_start")
  currentPeriodEnd      DateTime  @map("current_period_end")
  trialEnd              DateTime? @map("trial_end")
  canceledAt            DateTime? @map("canceled_at")
  cancelAtPeriodEnd     Boolean   @default(false) @map("cancel_at_period_end")
  paymentMethodId       String?   @map("payment_method_id")
  stripeSubscriptionId  String?   @map("stripe_subscription_id")
  metadata              Json      @default("{}")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  user                  User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                  SubscriptionPlan @relation(fields: [planId], references: [id])
  paymentMethod         PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  invoices              Invoice[]

  @@map("subscriptions")
}

model PaymentMethod {
  id                       String    @id @default(uuid())
  userId                   String?   @map("user_id")
  organizationId           String?   @map("organization_id")
  type                     PaymentType
  provider                 String
  providerPaymentMethodId  String    @map("provider_payment_method_id")
  last4                    String?
  brand                    String?
  expiryMonth              Int?      @map("expiry_month")
  expiryYear               Int?      @map("expiry_year")
  isDefault                Boolean   @default(false) @map("is_default")
  metadata                 Json      @default("{}")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  // Relations
  user                     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization             Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions            Subscription[]
  invoices                 Invoice[]

  @@map("payment_methods")
}

model Invoice {
  id                String    @id @default(uuid())
  userId            String?   @map("user_id")
  organizationId    String?   @map("organization_id")
  subscriptionId    String?   @map("subscription_id")
  number            String    @unique
  status            InvoiceStatus @default(DRAFT)
  currency          String    @default("UZS")
  amount            Decimal   @db.Decimal(10, 0)
  tax               Decimal   @default(0) @db.Decimal(10, 0)
  total             Decimal   @db.Decimal(10, 0)
  dueDate           DateTime? @map("due_date")
  paidAt            DateTime? @map("paid_at")
  paymentMethodId   String?   @map("payment_method_id")
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  user              User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  paymentMethod     PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@map("invoices")
}

model UsageTracking {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  organizationId String? @map("organization_id")
  feature       String
  action        String
  quantity      Int      @default(1)
  metadata      Json     @default("{}")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  user          User?     @relation(fields: [userId], references: [id])
  organization  Organization? @relation(fields: [organizationId], references: [id])

  @@map("usage_tracking")
}

model UserAnalytics {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  date                  DateTime @db.Date
  sessions              Int      @default(0)
  pageViews             Int      @default(0) @map("page_views")
  iracCasesCompleted    Int      @default(0) @map("irac_cases_completed")
  aiRequests            Int      @default(0) @map("ai_requests")
  studyTimeMinutes      Int      @default(0) @map("study_time_minutes")
  achievementsUnlocked  Int      @default(0) @map("achievements_unlocked")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  user                  User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("user_analytics")
}

model OrganizationAnalytics {
  id            String   @id @default(uuid())
  organizationId String   @map("organization_id")
  date          DateTime @db.Date
  activeUsers   Int      @default(0) @map("active_users")
  newUsers      Int      @default(0) @map("new_users")
  totalSessions Int      @default(0) @map("total_sessions")
  totalIracCases Int     @default(0) @map("total_irac_cases")
  totalAiRequests Int    @default(0) @map("total_ai_requests")
  revenue       Decimal  @default(0) @db.Decimal(10, 0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  organization  Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, date])
  @@map("organization_analytics")
}

model IracCase {
  id              String    @id @default(uuid())
  userId          String?   @map("user_id")
  organizationId  String?   @map("organization_id")
  title           String
  caseText        String    @map("case_text")
  caseType        CaseType  @map("case_type")
  difficultyLevel Difficulty @map("difficulty_level")
  issue           String?
  rule            String?
  application     String?
  conclusion      String?
  scores          Json      @default("{}")
  totalScore      Int?      @map("total_score")
  feedback        String?
  suggestions     Json      @default("[]")
  status          CaseStatus @default(DRAFT)
  isPublic        Boolean   @default(false) @map("is_public")
  tags            Json      @default("[]")
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User?     @relation(fields: [userId], references: [id])
  organization    Organization? @relation(fields: [organizationId], references: [id])

  @@map("irac_cases")
}

model Achievement {
  id              String    @id @default(uuid())
  userId          String?   @map("user_id")
  organizationId  String?   @map("organization_id")
  achievementType String    @map("achievement_type")
  title           String
  description     String?
  rarity          Rarity    @default(COMMON)
  points          Int       @default(0)
  iconUrl         String?   @map("icon_url")
  metadata        Json      @default("{}")
  unlockedAt      DateTime  @default(now()) @map("unlocked_at")

  // Relations
  user            User?     @relation(fields: [userId], references: [id])
  organization    Organization? @relation(fields: [organizationId], references: [id])

  @@map("achievements")
}

model ApiKey {
  id            String    @id @default(uuid())
  userId        String?   @map("user_id")
  organizationId String?  @map("organization_id")
  name          String
  keyHash       String    @unique @map("key_hash")
  permissions   Json      @default("{}")
  rateLimit     Int       @default(1000) @map("rate_limit")
  isActive      Boolean   @default(true) @map("is_active")
  expiresAt     DateTime? @map("expires_at")
  lastUsedAt    DateTime? @map("last_used_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model SystemSetting {
  id          String    @id @default(uuid())
  key         String    @unique
  value       String?
  type        SettingType @default(STRING)
  description String?
  isPublic    Boolean   @default(false) @map("is_public")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Feedback {
  id          String      @id @default(uuid())
  type        String      // 'bug' | 'feature' | 'improvement' | 'other'
  title       String
  description String
  email       String?
  userId      String?     @map("user_id")
  userAgent   String?     @map("user_agent")
  url         String?
  status      String      @default("NEW") // 'NEW' | 'IN_PROGRESS' | 'RESOLVED' | 'CLOSED'
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("feedback")
}

// Enums
enum UserRole {
  STUDENT
  TEACHER
  ADMIN
  INSTITUTION
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum OrgStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MemberStatus {
  ACTIVE
  PENDING
  INACTIVE
  REMOVED
}

enum BillingCycle {
  MONTHLY
  YEARLY
  QUARTERLY
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

enum PaymentType {
  CARD
  BANK_ACCOUNT
  PAYPAL
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum CaseType {
  CIVIL
  CRIMINAL
  FAMILY
  LABOR
  ADMINISTRATIVE
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum CaseStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum SettingType {
  STRING
  INTEGER
  BOOLEAN
  JSON
  DECIMAL
}
