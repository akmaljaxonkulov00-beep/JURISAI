# ==================== JURISAI ENVIRONMENT VARIABLES ====================
# Copy this file to .env.local and fill with YOUR OWN values
# NEVER commit .env.local to git!

# ==================== REQUIRED ====================

# Supabase Database (REQUIRED - Get from https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_new_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_new_service_role_key_here
NEXT_PUBLIC_SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1

# NextAuth (REQUIRED - Generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=generate_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# AI Provider (REQUIRED - Only Groq!)
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_new_groq_key_here


# ==================== OPTIONAL ====================

# Redis Cache (optional - for better performance)
REDIS_URL=redis://localhost:6379

# PostgreSQL (optional - if not using Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/jurisai

# Stripe Payment (optional - for premium features)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@jurisai.uz

# Monitoring (optional - for error tracking)
SENTRY_DSN=your_sentry_dsn_here
NEXT_PUBLIC_SENTRY_DSN=your_public_sentry_dsn

# Telegram Bot (optional - for notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ==================== DEVELOPMENT ====================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEBUG=false
